APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dhn
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database

# External document processing (required for upload / datasheet endpoints)
PROCESSING_SERVICE_BASE_URL=http://127.0.0.1
PROCESSING_SERVICE_USERNAME=api_user
PROCESSING_SERVICE_PASSWORD=
PROCESSING_SERVICE_CONNECT_TIMEOUT=60
PROCESSING_SERVICE_TIMEOUT=600
PROCESSING_SERVICE_READ_TIMEOUT=600
PROCESSING_USE_QUEUE=false

# Optional path overrides (defaults in config/processing.php)
# PROCESSING_ENDPOINT_DATASHEET=/datasheet_process
# PROCESSING_ENDPOINT_STHAMER=/sthamer/datasheet_process
